SEED_USER_1_NAME="Your Name"
SEED_USER_1_PASSWORD="choose-a-real-password"
SEED_USER_2_EMAIL="partner@example.com"
SEED_USER_2_NAME="Partner Name"
SEED_USER_2_PASSWORD="choose-a-real-password"
